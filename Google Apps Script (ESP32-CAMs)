function doPost(e) {

  var cameraId = e.parameter.cameraId;   // CAM_1, CAM_2, CAM_3
  var data = Utilities.base64Decode(e.parameter.data);

  var nombreArchivo =
    Utilities.formatDate(new Date(), "GMT+8", "yyyyMMdd_HHmm") +
    "_" + cameraId + ".jpg";

  var blob = Utilities.newBlob(data, e.parameter.mimetype, nombreArchivo);

  // ===== Folder mapping =====
  var folderMap = {
    "CAM_1": "ESP32-CAM-1",
    "CAM_2": "ESP32-CAM-2",
    "CAM_3": "ESP32-CAM-3"
  };

  var folderName = folderMap[cameraId] || "ESP32-CAM-UNKNOWN";

  var folder, folders = DriveApp.getFoldersByName(folderName);
  if (folders.hasNext()) {
    folder = folders.next();
  } else {
    folder = DriveApp.createFolder(folderName);
  }

  folder.createFile(blob);

  return ContentService.createTextOutput("Completed");
}
